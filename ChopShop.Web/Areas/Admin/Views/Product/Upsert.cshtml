@model ProductVM
<div class="border-0 card shadow my-4">
    <div class="card-header text-center bg-primary text-white py-3 rounded-top">
        <h2 class="mb-0">@(Model.Product.Id < 1 ? "Create " : "Update ")Product</h2>
    </div>
    <div class="card-body p-4">
        <form method="post" enctype="multipart/form-data">
            <input asp-for="Product.Id" hidden />
            <input asp-for="Product.ImageUrl" hidden />
            <div class="row">
                <!-- Form -->
                <div class="col-12 col-md-9">
                    <div class="form-floating py-2 mb-2">
                        <input asp-for="Product.Title" class="form-control" autofocus />
                        <label asp-for="Product.Title">Title</label>
                        <span asp-validation-for="Product.Title" class="text-danger"></span>
                    </div>
                    <div class="form-floating py-2 mb-2">
                        <textarea asp-for="Product.Description" class="form-control" style="height: 100px;"></textarea>
                        <label asp-for="Product.Description">Description</label>
                        <span asp-validation-for="Product.Description" class="text-danger"></span>
                    </div>
                    <div class="form-floating py-2 mb-2">
                        <input asp-for="Product.Price" type="number" class="form-control" />
                        <label asp-for="Product.Price">Price</label>
                        <span asp-validation-for="Product.Price" class="text-danger"></span>
                    </div>
                    <div class="form-floating py-2 mb-2">
                        <select asp-for="Product.CategoryId" asp-items="@Model.CategoryList" class="form-select">
                            <option selected>-- Select Category --</option>
                        </select>
                        <label asp-for="Product.CategoryId">Category</label>
                        <span asp-validation-for="Product.CategoryId"></span>

                    </div>
                    <div class="py-2 mb-2">
                        <label asp-for="Product.ImageUrl" class="form-label">Product Image</label>
                        <input asp-for="Product.ImageUrl" type="file" name="file" class="form-control" />
                        <span asp-validation-for="Product.ImageUrl"></span>
                    </div>
                </div>
                <!-- Image -->
                <div class="col-12 col-md-3 mt-3 mt-md-0 d-flex justify-content-center align-items-center">
                    @if (!string.IsNullOrEmpty(Model.Product.ImageUrl))
                    {
                        <img src="/@Model.Product.ImageUrl" alt="Product Image" class="img-fluid rounded shadow" style="border:1px solid #ccc; max-height: 250px; object-fit: contain;" />
                    }
                    else
                    {
                        <div class="text-muted text-center border p-3 rounded" style="max-height: 250px; width: 100%; display: flex; align-items: center; justify-content: center;">
                            No Image Selected
                        </div>
                    }
                </div>
            </div>
            <!-- Buttons -->
            <div class="col-12 mt-4">
                <div class="row">
                    <div class="col-12 col-md-6 mb-2 mb-md-0">

                        <button type="submit" class="btn btn-primary form-control w-100"><i class="fa-solid @(Model.Product.Id < 1 ? "fa-plus-circle" : "fa-edit") me-2"></i>@(Model.Product.Id < 1 ? "Create" : "Update")</button>
                    </div>
                    <div class="col-12 col-md-6">
                        <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary form-control w-100"><i class="fas fa-arrow-alt-circle-left me-2"></i> Back To List</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
@* for adding client side validations *@
@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}