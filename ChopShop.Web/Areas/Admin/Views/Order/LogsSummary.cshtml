@model OrderLogsVM
@Html.AntiForgeryToken()
<div class="container py-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary bg-gradient text-white d-flex align-items-center justify-content-between flex-wrap p-3">
            <h2 class="h5 mb-0 me-2">
                <i class="fas fa-chart-line me-2" aria-hidden="true"></i> Orders Logs Summary
            </h2>
            <a class="btn btn-outline-light btn-sm" asp-controller="Order" asp-action="Logs">
                <i class="fas fa-arrow-left me-1" aria-hidden="true"></i> Select Time Length
            </a>
        </div>
        <div class="card-body p-4">
            <form method="get" class="w-100">
                <div class="row g-4">
                    <div class="col-12 col-lg-8">
                        <div class="bg-light border rounded p-3 mb-4">
                            <h3 class="h6 fw-bold mb-3 text-muted d-flex align-items-center gap-2">
                                <i class="fas fa-receipt me-1" aria-hidden="true"></i> Delivery & Metrics (From @Model.StartDate.ToShortDateString() To @Model.EndDate.ToShortDateString())
                            </h3>
                            <div class="row g-3">
                                <div class="col-12 col-md-6">
                                    <label class="form-label fw-semibold" asp-for="CountOfOrders">Orders Count</label>
                                    <input readonly class="form-control" asp-for="CountOfOrders" type="text" />
                                </div>
                                <div class="col-12 col-md-6">
                                    <label class="form-label fw-semibold" asp-for="CountOfSelledItems">Selled Items Count</label>
                                    <input readonly class="form-control" asp-for="CountOfSelledItems" type="text" />
                                </div>
                                <div class="col-12">
                                    <div class="bg-white border rounded p-3">
                                        <div class="d-flex align-items-center justify-content-between gap-3">
                                            <div>
                                                <div class="text-muted small mb-1">Most Value Order</div>
                                                <div class="fw-bold fs-5">
                                                    @Model?.MostValueOrder?.OrderTotal.ToString("C")
                                                </div>
                                            </div>
                                            <i class="fas fa-award text-warning fs-4" aria-hidden="true"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <label class="form-label fw-semibold" asp-for="TotalFee">Total Fee</label>
                                    <div class="input-group">
                                        <span class="input-group-text">$</span>
                                        <input readonly class="form-control" type="text" value="@Model?.TotalFee.ToString("N2")" />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="bg-light border rounded p-3">
                            <h3 class="h6 fw-bold mb-3 text-muted d-flex align-items-center gap-2">
                                <i class="fas fa-list me-1" aria-hidden="true"></i> List Of Orders
                            </h3>
                            <div class="row g-3">
                                @if (Model?.ListOfOrders != null && Model.ListOfOrders.Count() > 0)
                                {
                                    <table class="table table-striped text-center table-bordered align-middle mt-3 mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Name</th>
                                                <th>Phone Number</th>
                                                <th>Order Date</th>
                                                <th>Order Total</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var order in Model.ListOfOrders)
                                            {
                                                <tr>
                                                    <td class="fw-semibold">@order.Name</td>
                                                    <td class="fw-semibold">@order.PhoneNumber</td>
                                                    <td class="fw-semibold">@order.OrderDate</td>
                                                    <td class="fw-semibold ">@order.OrderTotal.ToString("C")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }
                                else
                                {
                                    <div class="col-12 text-muted">
                                        No items found.
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="bg-light border rounded p-3 mt-4">
                            <h3 class="h6 fw-bold mb-3 text-muted d-flex align-items-center gap-2">
                                <i class="fas fa-angle-double-up" aria-hidden="true"></i> Top Selled Products
                            </h3>
                            @if (Model?.TopSelledProducts != null && Model.TopSelledProducts.Count > 0)
                            {
                                <table class="table table-striped text-center table-bordered align-middle mt-2 mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Title</th>
                                            <th>Image</th>
                                            <th>Total Sold</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.TopSelledProducts)
                                        {
                                            <tr>
                                                <td class="fw-semibold">@item.Title</td>
                                                <td style="width:140px;height:100px">
                                                    @if (!string.IsNullOrWhiteSpace(item.ImgUrl))
                                                    {
                                                        <img src="~/@item.ImgUrl"
                                                             alt="@item.Title"
                                                             style="width:100px; height:60px; object-fit:cover; border-radius:6px;" />
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">No Image</span>
                                                    }
                                                </td>
                                                <td class="fw-semibold">@item.TotalCount</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <div class="col-12 text-muted">
                                    No top products found.
                                </div>
                            }
                        </div>

                    </div>
                    <div class="col-12 col-lg-4">
                        <div class="bg-light border rounded p-4 sticky-top" style="top: 20px;">
                            <h4 class="h5 text-muted mb-3 border-bottom pb-2">
                                <i class="fas fa-sliders-h me-2" aria-hidden="true"></i> Summary
                            </h4>
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="text-muted">Orders Count</span>
                                <span class="fw-bold">@Model.CountOfOrders</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="text-muted">Selled Items Count</span>
                                <span class="fw-bold">@Model.CountOfSelledItems</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
                                <span class="text-muted">Most Value</span>
                                <span class="fw-bold text-success">@Model?.MostValueOrder?.OrderTotal.ToString("C")</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="fw-semibold">Total Fee</span>
                                <span class="fs-4 text-success fw-bold">$@Model?.TotalFee.ToString("N2")</span>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

