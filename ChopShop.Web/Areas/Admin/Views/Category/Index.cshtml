@model List<Category>
<div class="container py-4">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-primary text-white py-3">
            <div class="row align-items-center">
                <div class="col">
                    <h2 class="mb-0 text-center text-md-start">Category List</h2>
                </div>
                <div class="col-auto">
                    <a asp-controller="Category" asp-action="Upsert" class="btn btn-light btn-sm text-primary">
                        <i class="fas fa-plus-circle me-2"></i> Create New Category
                    </a>
                </div>
            </div>
        </div>
        <div class="card-body p-4">
            @if (Model == null || !Model.Any())
            {
                <div class="alert alert-info text-center" role="alert">
                    No categories found. Click "Create New Category" to add one.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-bordered table-striped table-hover mb-0">
                        <thead>
                            <tr>
                                <th scope="col" class="text-nowrap">Category Name</th>
                                <th scope="col" class="text-nowrap">Display Order</th>
                                <th scope="col" class="text-center text-nowrap" style="width: 150px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var category in Model)
                            {
                                <tr>
                                    <td>@category.Name</td>
                                    <td>@category.DisplayOrder</td>
                                    <td class="text-center">

                                        <div class="btn-group" role="group">
                                            <a asp-controller="Category" asp-action="Upsert" asp-route-id="@category.Id" class="btn btn-primary btn-sm me-2" title="Edit Category">
                                                <i class="fas fa-edit"></i> Edit
                                            </a>
                                            <a onclick="Delete('/admin/category/delete/@category.Id')" class="btn btn-danger btn-sm" title="Delete Category">
                                                <i class="fas fa-trash-alt"></i> Delete
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
