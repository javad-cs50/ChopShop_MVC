<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @SD.WebSiteName</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ChopShop.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/all.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sweetalert2.min.css" />
    <link rel="stylesheet" href="~/css/jquery.dataTables.min.css" />
    <link rel="stylesheet" href="~/css/toastr.min.css" />
</head>
<body class="bg-secondary-subtle">
    <header>
        <nav id="mainNavbar" class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
        <partial name="_Notification" />
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="Customer" asp-controller="Home" asp-action="Index"><img src="~/Images/Logo/Logo.jpg" width="60px" class="icon-link rounded-circle" /><strong> @SD.WebSiteName</strong></a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse text-light collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <form asp-action="Index" method="get">
                            <div class="input-group m-2">
                                <input type="text" name="SearchTerm" class="form-control" placeholder="Product,Category,..." value="@ViewBag.CurrentFilter" />
                                <button class="btn btn-outline-secondary" type="submit">Search</button>
                            </div>
                        </form>
                        @if (User.IsInRole(SD.Role_Admin) || User.IsInRole(SD.Role_Employee))
                        {

                            <li class="nav-item dropdown m-2">
                                <a class="nav-link dropdown-toggle text-white" href="#" role="button" data-bs-toggle="dropdown">Management</a>

                                <ul class="dropdown-menu dropdown-menu-dark">

                                    <li class="nav-item">
                                        <a class="dropdown-item" asp-area="Identity" asp-controller="Account" asp-action="Index">Users</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="dropdown-item" asp-area="Admin" asp-controller="Category" asp-action="Index">Categories</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="dropdown-item" asp-area="Admin" asp-controller="Product" asp-action="Index">Products</a>
                                    </li>
                                    <hr class="dropdown-divider border-light">
                                    <li class="nav-item">
                                        <a class="dropdown-item" asp-area="Admin" asp-controller="Order" asp-action="Logs">OrderLogs</a>
                                    </li>

                                </ul>
                            </li>

                        }
                        @if (User.IsInRole(SD.Role_Customer))
                        {
                            <li class="nav-item">
                                <a class="btn text-light m-2" asp-area="Customer" asp-controller="Cart" asp-action="index"><i class="fas fa-cart-shopping"></i></a>
                            </li>
                        }
                        @if (User.IsInRole(SD.Role_Employee)||User.IsInRole(SD.Role_Admin) || User.IsInRole(SD.Role_Customer))
                        {
                            <li class="nav-item">
                                <a class="text-light mt-2 btn" asp-area="Admin" asp-controller="Order" asp-action="Index">Orders</a>
                            </li>
                        }
                    </ul>
                    <ul class="nav m-1">
                        <partial name="_LoginPartial" />
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container ">
        <main role="main" class="pb-3 text-dark">
            @RenderBody()
        </main>
    </div>
    <footer class="footer border-top bg-dark text-muted">
        <div class="container text-center text-light">
            <span>&copy; 2026 - @SD.WebSiteName - </span>
            <span>Made With <i class="text-danger">&hearts;</i> By Mr.Abbaspour</span>
        </div>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/lib/jquery/dist/jquery.js"></script>
    <script src="~/js/sweetalert2.all.min.js"></script>
    <script src="~/js/toastr.min.js"></script>
    <script src="~/js/jquery.dataTables.min.js"></script>
    <script src="~/js/product.js"></script>
    <style>
        body {
            background-color: #f8f9fa;
            color: #212529;
        }

        .navbar-dark .navbar-nav .nav-link {
            color: rgba(255, 255, 255, 0.85);
        }

            .navbar-dark .navbar-nav .nav-link:hover,
            .navbar-dark .navbar-nav .nav-link:focus {
                color: rgba(255, 255, 255, 1);
            }

        .dropdown-menu-dark .dropdown-item {
            color: rgba(255, 255, 255, 0.85);
        }

            .dropdown-menu-dark .dropdown-item:hover,
            .dropdown-menu-dark .dropdown-item:focus {
                background-color: rgba(255, 255, 255, 0.1);
                color: rgba(255, 255, 255, 1);
            }

        .fixed-navbar {
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1030;
            animation: slideDown 0.3s ease-out;
            background-color: #212529 !important;
            border-bottom: 1px solid #495057 !important;
        }
    </style>
    <script>
                document.addEventListener('DOMContentLoaded', function () {
                    const navbar = document.getElementById('mainNavbar');
                    let navbarHeight = navbar.offsetHeight;
                    let isFixed = false;
        function handleScroll() {
                        if (window.scrollY > navbarHeight && !isFixed) {
                            navbar.classList.add('fixed-navbar');
                            document.body.style.paddingTop = navbarHeight + 'px';
                            isFixed = true;
                        } else if (window.scrollY <= navbarHeight && isFixed) {
                            navbar.classList.remove('fixed-navbar');
                            document.body.style.paddingTop = '0';
                            isFixed = false;
                        }
                    }
        window.addEventListener('scroll', handleScroll);
                    window.addEventListener('resize', () => {
                        navbarHeight = navbar.offsetHeight;
                        handleScroll();
                    });
                    handleScroll();
                });
    </script>
</body>
</html>
